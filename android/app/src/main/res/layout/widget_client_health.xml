<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@drawable/widget_background"
    android:padding="12dp"
    android:gravity="center">

    <!-- Header / Brand info -->
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="4dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="CREDIT HEALTH"
            android:textColor="#8A99AD"
            android:textSize="9sp"
            android:textStyle="bold"
            android:letterSpacing="0.05"
            android:layout_alignParentStart="true" />

        <TextView
            android:id="@+id/offline_dot"
            android:layout_width="5dp"
            android:layout_height="5dp"
            android:background="@drawable/offline_dot_red"
            android:layout_alignParentEnd="true"
            android:layout_centerVertical="true"
            android:visibility="gone" />
    </RelativeLayout>

    <!-- Score display inside a circular card -->
    <LinearLayout
        android:layout_width="60dp"
        android:layout_height="60dp"
        android:background="@drawable/score_card_background"
        android:orientation="vertical"
        android:gravity="center"
        android:layout_margin="4dp">

        <TextView
            android:id="@+id/txt_score_value"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="--"
            android:textColor="#FFFFFF"
            android:textSize="20sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/txt_score_label"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Score"
            android:textColor="#8A99AD"
            android:textSize="8sp"
            android:textAllCaps="true" />
    </LinearLayout>

    <!-- Streak Indicator -->
    <TextView
        android:id="@+id/txt_streak_value"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Streak: -- months"
        android:textColor="#FFFFFF"
        android:textSize="9sp"
        android:textStyle="bold"
        android:layout_marginTop="2dp" />

    <!-- Health Tier Badge -->
    <TextView
        android:id="@+id/txt_health_tier"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="N/A"
        android:textColor="#d4af37"
        android:textSize="10sp"
        android:textStyle="bold"
        android:layout_marginTop="2dp"
        android:letterSpacing="0.05" />
</LinearLayout>
