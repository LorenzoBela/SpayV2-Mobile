<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@drawable/widget_background"
    android:padding="16dp"
    android:gravity="center_vertical">

    <!-- Header -->
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="12dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="PLATFORM OVERVIEW &amp; METRICS"
            android:textColor="#8A99AD"
            android:textSize="9sp"
            android:textStyle="bold"
            android:letterSpacing="0.05"
            android:layout_alignParentStart="true" />

        <TextView
            android:id="@+id/offline_dot"
            android:layout_width="6dp"
            android:layout_height="6dp"
            android:background="@drawable/offline_dot_red"
            android:layout_alignParentEnd="true"
            android:layout_centerVertical="true"
            android:visibility="gone" />
    </RelativeLayout>

    <!-- 3-Column Metrics Layout -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:baselineAligned="false">

        <!-- Column 1: Clients -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="CLIENTS"
                android:textColor="#8A99AD"
                android:textSize="8sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/txt_stat_clients"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="--"
                android:textColor="#FFFFFF"
                android:textSize="18sp"
                android:textStyle="bold"
                android:layout_marginTop="2dp" />
        </LinearLayout>

        <!-- Vertical divider line -->
        <TextView
            android:layout_width="1dp"
            android:layout_height="24dp"
            android:background="#22FFFFFF"
            android:layout_gravity="center_vertical" />

        <!-- Column 2: Orders -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="ORDERS"
                android:textColor="#8A99AD"
                android:textSize="8sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/txt_stat_orders"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="--"
                android:textColor="#FFFFFF"
                android:textSize="18sp"
                android:textStyle="bold"
                android:layout_marginTop="2dp" />
        </LinearLayout>

        <!-- Vertical divider line -->
        <TextView
            android:layout_width="1dp"
            android:layout_height="24dp"
            android:background="#22FFFFFF"
            android:layout_gravity="center_vertical" />

        <!-- Column 3: Collection efficiency -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="COLLECT RATE"
                android:textColor="#8A99AD"
                android:textSize="8sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/txt_stat_efficiency"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="--%"
                android:textColor="#ee4d2d"
                android:textSize="18sp"
                android:textStyle="bold"
                android:layout_marginTop="2dp" />
        </LinearLayout>
    </LinearLayout>

    <!-- Footer -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:text="Tap to open admin dashboard metrics"
        android:textColor="#8A99AD"
        android:textSize="8sp"
        android:gravity="center"
        android:textStyle="italic" />
</LinearLayout>
