<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@drawable/widget_background"
    android:padding="16dp">

    <!-- Header -->
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="12dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="UPCOMING INSTALLMENTS"
            android:textColor="#8A99AD"
            android:textSize="10sp"
            android:textStyle="bold"
            android:letterSpacing="0.1"
            android:layout_alignParentStart="true" />

        <TextView
            android:id="@+id/offline_dot"
            android:layout_width="6dp"
            android:layout_height="6dp"
            android:background="@drawable/offline_dot_red"
            android:layout_alignParentEnd="true"
            android:layout_centerVertical="true"
            android:visibility="gone" />
    </RelativeLayout>

    <!-- Empty State -->
    <TextView
        android:id="@+id/txt_empty_state"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:gravity="center"
        android:text="All payments caught up! 🎉"
        android:textColor="#34c759"
        android:textSize="12sp"
        android:visibility="gone" />

    <!-- List Container -->
    <LinearLayout
        android:id="@+id/upcoming_list_container"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical"
        android:divider="?android:attr/dividerHorizontal"
        android:showDividers="middle">

        <!-- Row 1 -->
        <RelativeLayout
            android:id="@+id/upcoming_row_1"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingVertical="8dp">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_alignParentStart="true"
                android:layout_toStartOf="@id/layout_row_1_right"
                android:layout_centerVertical="true">

                <TextView
                    android:id="@+id/txt_row_1_desc"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Installment Order"
                    android:textColor="#FFFFFF"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:ellipsize="end"
                    android:maxLines="1" />

                <TextView
                    android:id="@+id/txt_row_1_due_info"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Due in -- days"
                    android:textColor="#8A99AD"
                    android:textSize="9sp" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/layout_row_1_right"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="end"
                android:layout_alignParentEnd="true"
                android:layout_centerVertical="true">

                <TextView
                    android:id="@+id/txt_row_1_amount"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="₱0.00"
                    android:textColor="#FFFFFF"
                    android:textSize="12sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/txt_row_1_overdue_badge"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="OVERDUE"
                    android:textColor="#ff3b30"
                    android:textSize="8sp"
                    android:textStyle="bold"
                    android:visibility="gone" />
            </LinearLayout>
        </RelativeLayout>

        <!-- Row 2 -->
        <RelativeLayout
            android:id="@+id/upcoming_row_2"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingVertical="8dp">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_alignParentStart="true"
                android:layout_toStartOf="@id/layout_row_2_right"
                android:layout_centerVertical="true">

                <TextView
                    android:id="@+id/txt_row_2_desc"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Installment Order"
                    android:textColor="#FFFFFF"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:ellipsize="end"
                    android:maxLines="1" />

                <TextView
                    android:id="@+id/txt_row_2_due_info"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Due in -- days"
                    android:textColor="#8A99AD"
                    android:textSize="9sp" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/layout_row_2_right"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="end"
                android:layout_alignParentEnd="true"
                android:layout_centerVertical="true">

                <TextView
                    android:id="@+id/txt_row_2_amount"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="₱0.00"
                    android:textColor="#FFFFFF"
                    android:textSize="12sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/txt_row_2_overdue_badge"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="OVERDUE"
                    android:textColor="#ff3b30"
                    android:textSize="8sp"
                    android:textStyle="bold"
                    android:visibility="gone" />
            </LinearLayout>
        </RelativeLayout>

        <!-- Row 3 -->
        <RelativeLayout
            android:id="@+id/upcoming_row_3"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingVertical="8dp">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_alignParentStart="true"
                android:layout_toStartOf="@id/layout_row_3_right"
                android:layout_centerVertical="true">

                <TextView
                    android:id="@+id/txt_row_3_desc"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Installment Order"
                    android:textColor="#FFFFFF"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:ellipsize="end"
                    android:maxLines="1" />

                <TextView
                    android:id="@+id/txt_row_3_due_info"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Due in -- days"
                    android:textColor="#8A99AD"
                    android:textSize="9sp" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/layout_row_3_right"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="end"
                android:layout_alignParentEnd="true"
                android:layout_centerVertical="true">

                <TextView
                    android:id="@+id/txt_row_3_amount"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="₱0.00"
                    android:textColor="#FFFFFF"
                    android:textSize="12sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/txt_row_3_overdue_badge"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="OVERDUE"
                    android:textColor="#ff3b30"
                    android:textSize="8sp"
                    android:textStyle="bold"
                    android:visibility="gone" />
            </LinearLayout>
        </RelativeLayout>
    </LinearLayout>

    <!-- Footer -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:text="Tap to view payment schedule details"
        android:textColor="#8A99AD"
        android:textSize="9sp"
        android:gravity="center"
        android:textStyle="italic" />
</LinearLayout>
