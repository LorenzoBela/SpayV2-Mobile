<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="horizontal"
    android:background="@drawable/widget_background"
    android:padding="12dp"
    android:gravity="center_vertical">

    <!-- Mascot Dog Avatar (Left) -->
    <RelativeLayout
        android:layout_width="60dp"
        android:layout_height="60dp"
        android:layout_marginRight="8dp">

        <ImageView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:src="@drawable/noot_mascot"
            android:scaleType="centerInside"
            android:contentDescription="Noot Mascot" />
    </RelativeLayout>

    <!-- Speech Prompt Bubble (Right) -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@drawable/speech_bubble_background"
        android:padding="8dp"
        android:layout_weight="1">

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="2dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="NOOTAI COPILOT"
                android:textColor="#FFEE4D2D"
                android:textSize="8sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/offline_dot"
                android:layout_width="5dp"
                android:layout_height="5dp"
                android:background="@drawable/offline_dot_red"
                android:layout_alignParentEnd="true"
                android:visibility="gone" />
        </RelativeLayout>

        <TextView
            android:id="@+id/txt_noot_prompt"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Secure &amp; Smart Payments"
            android:textColor="#FFFFFF"
            android:textSize="10sp"
            android:lineSpacingExtra="2dp" />
    </LinearLayout>
</LinearLayout>
