<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@drawable/widget_background"
    android:padding="16dp">

    <!-- Header -->
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="12dp">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_alignParentStart="true">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="NOTIFICATIONS"
                android:textColor="#8A99AD"
                android:textSize="10sp"
                android:textStyle="bold"
                android:letterSpacing="0.1" />

            <!-- Unread badge -->
            <TextView
                android:id="@+id/txt_unread_badge"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="6dp"
                android:background="@drawable/unread_dot_orange"
                android:paddingHorizontal="6dp"
                android:paddingVertical="1dp"
                android:text="0 NEW"
                android:textColor="#FFFFFF"
                android:textSize="8sp"
                android:textStyle="bold"
                android:visibility="gone" />
        </LinearLayout>

        <TextView
            android:id="@+id/offline_dot"
            android:layout_width="6dp"
            android:layout_height="6dp"
            android:background="@drawable/offline_dot_red"
            android:layout_alignParentEnd="true"
            android:layout_centerVertical="true"
            android:visibility="gone" />
    </RelativeLayout>

    <!-- Empty State -->
    <TextView
        android:id="@+id/txt_empty_state"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:gravity="center"
        android:text="Your inbox is clear. ✨"
        android:textColor="#34c759"
        android:textSize="12sp"
        android:visibility="gone" />

    <!-- List Container -->
    <LinearLayout
        android:id="@+id/inbox_list_container"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical"
        android:divider="?android:attr/dividerHorizontal"
        android:showDividers="middle">

        <!-- Row 1 -->
        <RelativeLayout
            android:id="@+id/inbox_row_1"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingVertical="8dp">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_alignParentStart="true"
                android:layout_toStartOf="@id/txt_row_1_time"
                android:layout_marginEnd="8dp">

                <TextView
                    android:id="@+id/txt_row_1_title"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Alert Title"
                    android:textColor="#FFFFFF"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:ellipsize="end"
                    android:maxLines="1" />

                <TextView
                    android:id="@+id/txt_row_1_body"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Notification message preview"
                    android:textColor="#8A99AD"
                    android:textSize="10sp"
                    android:ellipsize="end"
                    android:maxLines="1" />
            </LinearLayout>

            <TextView
                android:id="@+id/txt_row_1_time"
                android:layout_width="50dp"
                android:layout_height="wrap_content"
                android:text="--:--"
                android:textColor="#8A99AD"
                android:textSize="9sp"
                android:gravity="end"
                android:layout_alignParentEnd="true"
                android:layout_centerVertical="true" />
        </RelativeLayout>

        <!-- Row 2 -->
        <RelativeLayout
            android:id="@+id/inbox_row_2"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingVertical="8dp">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_alignParentStart="true"
                android:layout_toStartOf="@id/txt_row_2_time"
                android:layout_marginEnd="8dp">

                <TextView
                    android:id="@+id/txt_row_2_title"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Alert Title"
                    android:textColor="#FFFFFF"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:ellipsize="end"
                    android:maxLines="1" />

                <TextView
                    android:id="@+id/txt_row_2_body"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Notification message preview"
                    android:textColor="#8A99AD"
                    android:textSize="10sp"
                    android:ellipsize="end"
                    android:maxLines="1" />
            </LinearLayout>

            <TextView
                android:id="@+id/txt_row_2_time"
                android:layout_width="50dp"
                android:layout_height="wrap_content"
                android:text="--:--"
                android:textColor="#8A99AD"
                android:textSize="9sp"
                android:gravity="end"
                android:layout_alignParentEnd="true"
                android:layout_centerVertical="true" />
        </RelativeLayout>

        <!-- Row 3 -->
        <RelativeLayout
            android:id="@+id/inbox_row_3"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingVertical="8dp">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_alignParentStart="true"
                android:layout_toStartOf="@id/txt_row_3_time"
                android:layout_marginEnd="8dp">

                <TextView
                    android:id="@+id/txt_row_3_title"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Alert Title"
                    android:textColor="#FFFFFF"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:ellipsize="end"
                    android:maxLines="1" />

                <TextView
                    android:id="@+id/txt_row_3_body"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Notification message preview"
                    android:textColor="#8A99AD"
                    android:textSize="10sp"
                    android:ellipsize="end"
                    android:maxLines="1" />
            </LinearLayout>

            <TextView
                android:id="@+id/txt_row_3_time"
                android:layout_width="50dp"
                android:layout_height="wrap_content"
                android:text="--:--"
                android:textColor="#8A99AD"
                android:textSize="9sp"
                android:gravity="end"
                android:layout_alignParentEnd="true"
                android:layout_centerVertical="true" />
        </RelativeLayout>
    </LinearLayout>

    <!-- Footer -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:text="Tap to view all notifications"
        android:textColor="#8A99AD"
        android:textSize="9sp"
        android:gravity="center"
        android:textStyle="italic" />
</LinearLayout>
