<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@drawable/widget_background"
    android:padding="12dp">

    <!-- Header Section -->
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="8dp">

        <LinearLayout
            android:id="@+id/header_nav"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_alignParentStart="true">

            <ImageButton
                android:id="@+id/btn_prev_month"
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:background="?android:attr/selectableItemBackgroundBorderless"
                android:src="@android:drawable/ic_media_previous"
                android:contentDescription="Previous Month"
                android:tint="#FFFFFF" />

            <TextView
                android:id="@+id/txt_billing_cycle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="June 2026"
                android:textColor="#FFFFFF"
                android:textSize="14sp"
                android:textStyle="bold"
                android:layout_marginLeft="8dp"
                android:layout_marginRight="8dp" />

            <ImageButton
                android:id="@+id/btn_next_month"
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:background="?android:attr/selectableItemBackgroundBorderless"
                android:src="@android:drawable/ic_media_next"
                android:contentDescription="Next Month"
                android:tint="#FFFFFF" />
        </LinearLayout>

        <!-- Offline Warning Dot -->
        <View
            android:id="@+id/offline_dot"
            android:layout_width="8dp"
            android:layout_height="8dp"
            android:background="@android:drawable/presence_offline"
            android:backgroundTint="#ff3b30"
            android:layout_alignParentEnd="true"
            android:layout_centerVertical="true"
            android:visibility="gone" />
    </RelativeLayout>

    <!-- Countdown Clock Cards -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:layout_marginBottom="8dp">

        <!-- Days -->
        <LinearLayout
            android:layout_width="48dp"
            android:layout_height="54dp"
            android:orientation="vertical"
            android:background="@drawable/digit_card_background"
            android:gravity="center">
            <TextView
                android:id="@+id/txt_days"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="00"
                android:textColor="#FFFFFF"
                android:textSize="20sp"
                android:textStyle="bold" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="DAYS"
                android:textColor="#8A99AD"
                android:textSize="8sp" />
        </LinearLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text=":"
            android:textColor="#8A99AD"
            android:textSize="18sp"
            android:layout_marginLeft="4dp"
            android:layout_marginRight="4dp"
            android:layout_gravity="center_vertical" />

        <!-- Hours -->
        <LinearLayout
            android:layout_width="48dp"
            android:layout_height="54dp"
            android:orientation="vertical"
            android:background="@drawable/digit_card_background"
            android:gravity="center">
            <TextView
                android:id="@+id/txt_hours"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="00"
                android:textColor="#FFFFFF"
                android:textSize="20sp"
                android:textStyle="bold" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="HOURS"
                android:textColor="#8A99AD"
                android:textSize="8sp" />
        </LinearLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text=":"
            android:textColor="#8A99AD"
            android:textSize="18sp"
            android:layout_marginLeft="4dp"
            android:layout_marginRight="4dp"
            android:layout_gravity="center_vertical" />

        <!-- Min -->
        <LinearLayout
            android:layout_width="48dp"
            android:layout_height="54dp"
            android:orientation="vertical"
            android:background="@drawable/digit_card_background"
            android:gravity="center">
            <TextView
                android:id="@+id/txt_minutes"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="00"
                android:textColor="#FFFFFF"
                android:textSize="20sp"
                android:textStyle="bold" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="MINS"
                android:textColor="#8A99AD"
                android:textSize="8sp" />
        </LinearLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text=":"
            android:textColor="#8A99AD"
            android:textSize="18sp"
            android:layout_marginLeft="4dp"
            android:layout_marginRight="4dp"
            android:layout_gravity="center_vertical" />

        <!-- Sec -->
        <LinearLayout
            android:layout_width="48dp"
            android:layout_height="54dp"
            android:orientation="vertical"
            android:background="@drawable/digit_card_background"
            android:gravity="center">
            <TextView
                android:id="@+id/txt_seconds"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="00"
                android:textColor="#FFFFFF"
                android:textSize="20sp"
                android:textStyle="bold" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="SECS"
                android:textColor="#8A99AD"
                android:textSize="8sp" />
        </LinearLayout>
    </LinearLayout>

    <!-- Cycle collection details section -->
    <TextView
        android:id="@+id/txt_clock_status"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Remaining collection time for this cycle"
        android:textColor="#ee4d2d"
        android:textSize="9sp"
        android:gravity="center"
        android:layout_marginBottom="6dp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:layout_marginBottom="8dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="CYCLE REVENUE DUE: "
            android:textColor="#8A99AD"
            android:textSize="10sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/txt_cycle_due_amount"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="₱0.00"
            android:textColor="#FFFFFF"
            android:textSize="11sp"
            android:textStyle="bold" />
    </LinearLayout>

    <!-- Amortization breakdown rows inside widget -->
    <LinearLayout
        android:id="@+id/breakdown_container"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical"
        android:paddingHorizontal="4dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="PENDING SYSTEM CHECKS"
            android:textColor="#8A99AD"
            android:textSize="8sp"
            android:textStyle="bold"
            android:layout_marginBottom="4dp" />

        <!-- Row 1 -->
        <RelativeLayout
            android:id="@+id/breakdown_row_1"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="2dp">
            <TextView
                android:id="@+id/txt_row_1_desc"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Unverified Receipts"
                android:textColor="#FFFFFF"
                android:textSize="10sp"
                android:layout_alignParentStart="true" />
            <TextView
                android:id="@+id/txt_row_1_val"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0"
                android:textColor="#FFFFFF"
                android:textSize="10sp"
                android:textStyle="bold"
                android:layout_alignParentEnd="true" />
        </RelativeLayout>

        <!-- Row 2 -->
        <RelativeLayout
            android:id="@+id/breakdown_row_2"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="2dp">
            <TextView
                android:id="@+id/txt_row_2_desc"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Pending Verification"
                android:textColor="#FFFFFF"
                android:textSize="10sp"
                android:layout_alignParentStart="true" />
            <TextView
                android:id="@+id/txt_row_2_val"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0"
                android:textColor="#FFFFFF"
                android:textSize="10sp"
                android:textStyle="bold"
                android:layout_alignParentEnd="true" />
        </RelativeLayout>

        <!-- Row 3 -->
        <RelativeLayout
            android:id="@+id/breakdown_row_3"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">
            <TextView
                android:id="@+id/txt_row_3_desc"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Overdue Collection Accounts"
                android:textColor="#FFFFFF"
                android:textSize="10sp"
                android:layout_alignParentStart="true" />
            <TextView
                android:id="@+id/txt_row_3_val"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0"
                android:textColor="#FFFFFF"
                android:textSize="10sp"
                android:textStyle="bold"
                android:layout_alignParentEnd="true" />
        </RelativeLayout>
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:layout_marginTop="4dp">
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Tap to open admin workspace"
            android:textColor="#8A99AD"
            android:textSize="9sp"
            android:textStyle="italic" />
    </LinearLayout>
</LinearLayout>
