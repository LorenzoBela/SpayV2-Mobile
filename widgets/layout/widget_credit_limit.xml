<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@drawable/widget_background"
    android:padding="16dp"
    android:gravity="center_vertical">

    <!-- Card Header / Brand -->
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="8dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="S-PAY V2 PREMIUM"
            android:textColor="#8A99AD"
            android:textSize="10sp"
            android:textStyle="bold"
            android:letterSpacing="0.1"
            android:layout_alignParentStart="true" />

        <TextView
            android:id="@+id/offline_dot"
            android:layout_width="6dp"
            android:layout_height="6dp"
            android:background="@drawable/offline_dot_red"
            android:layout_alignParentEnd="true"
            android:layout_centerVertical="true"
            android:visibility="gone" />
    </RelativeLayout>

    <!-- Card Body: Chip & Numbers -->
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="12dp">

        <!-- Mock Chip -->
        <TextView
            android:id="@+id/card_chip"
            android:layout_width="28dp"
            android:layout_height="20dp"
            android:background="@drawable/chip_gold_background"
            android:layout_alignParentStart="true"
            android:layout_centerVertical="true" />

        <TextView
            android:id="@+id/txt_card_number"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="**** **** **** 9114"
            android:textColor="#FFFFFF"
            android:textSize="12sp"
            android:letterSpacing="0.05"
            android:layout_alignParentEnd="true"
            android:layout_centerVertical="true" />
    </RelativeLayout>

    <!-- Credit Limit Display Section -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="AVAILABLE CREDIT LIMIT"
        android:textColor="#8A99AD"
        android:textSize="8sp" />

    <TextView
        android:id="@+id/txt_available_credit"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="₱0.00"
        android:textColor="#FFFFFF"
        android:textSize="22sp"
        android:textStyle="bold"
        android:layout_marginBottom="2dp" />

    <TextView
        android:id="@+id/txt_baseline_limit"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Global Baseline: ₱0.00"
        android:textColor="#8A99AD"
        android:textSize="9sp"
        android:layout_marginBottom="8dp" />

    <!-- Custom Progress Bar -->
    <ProgressBar
        android:id="@+id/limit_progress"
        style="?android:attr/progressBarStyleHorizontal"
        android:layout_width="match_parent"
        android:layout_height="4dp"
        android:progress="0"
        android:max="100"
        android:progressDrawable="@drawable/progress_bar_horizontal"
        android:layout_marginBottom="8dp" />

    <!-- Cardholder Name Footer -->
    <TextView
        android:id="@+id/txt_cardholder_name"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="LORENZO BELA"
        android:textColor="#FFFFFF"
        android:textSize="10sp"
        android:textStyle="bold"
        android:letterSpacing="0.05" />
</LinearLayout>
