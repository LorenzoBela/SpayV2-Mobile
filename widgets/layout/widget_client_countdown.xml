<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@drawable/widget_background"
    android:padding="12dp">

    <!-- Header Section -->
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="8dp">

        <LinearLayout
            android:id="@+id/header_nav"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_alignParentStart="true">

            <ImageButton
                android:id="@+id/btn_prev_month"
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:background="?android:attr/selectableItemBackgroundBorderless"
                android:src="@android:drawable/ic_media_previous"
                android:contentDescription="Previous Month" />

            <TextView
                android:id="@+id/txt_billing_cycle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="June 2026"
                android:textColor="#FFFFFF"
                android:textSize="14sp"
                android:textStyle="bold"
                android:layout_marginLeft="8dp"
                android:layout_marginRight="8dp" />

            <ImageButton
                android:id="@+id/btn_next_month"
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:background="?android:attr/selectableItemBackgroundBorderless"
                android:src="@android:drawable/ic_media_next"
                android:contentDescription="Next Month" />
        </LinearLayout>

        <!-- Offline Warning Dot -->
        <TextView
            android:id="@+id/offline_dot"
            android:layout_width="8dp"
            android:layout_height="8dp"
            android:background="@drawable/offline_dot_red"
            android:layout_alignParentEnd="true"
            android:layout_centerVertical="true"
            android:visibility="gone" />
    </RelativeLayout>

    <!-- Countdown Clock Cards -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:layout_marginBottom="8dp">

        <!-- Days -->
        <LinearLayout
            android:layout_width="48dp"
            android:layout_height="54dp"
            android:orientation="vertical"
            android:background="@drawable/digit_card_background"
            android:gravity="center">
            <TextView
                android:id="@+id/txt_days"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="00"
                android:textColor="#FFFFFF"
                android:textSize="20sp"
                android:textStyle="bold" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="DAYS"
                android:textColor="#8A99AD"
                android:textSize="8sp" />
        </LinearLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text=":"
            android:textColor="#8A99AD"
            android:textSize="18sp"
            android:layout_marginLeft="4dp"
            android:layout_marginRight="4dp"
            android:layout_gravity="center_vertical" />

        <!-- Hours -->
        <LinearLayout
            android:layout_width="48dp"
            android:layout_height="54dp"
            android:orientation="vertical"
            android:background="@drawable/digit_card_background"
            android:gravity="center">
            <TextView
                android:id="@+id/txt_hours"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="00"
                android:textColor="#FFFFFF"
                android:textSize="20sp"
                android:textStyle="bold" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="HOURS"
                android:textColor="#8A99AD"
                android:textSize="8sp" />
        </LinearLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text=":"
            android:textColor="#8A99AD"
            android:textSize="18sp"
            android:layout_marginLeft="4dp"
            android:layout_marginRight="4dp"
            android:layout_gravity="center_vertical" />

        <!-- Min -->
        <LinearLayout
            android:layout_width="48dp"
            android:layout_height="54dp"
            android:orientation="vertical"
            android:background="@drawable/digit_card_background"
            android:gravity="center">
            <TextView
                android:id="@+id/txt_minutes"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="00"
                android:textColor="#FFFFFF"
                android:textSize="20sp"
                android:textStyle="bold" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="MIN"
                android:textColor="#8A99AD"
                android:textSize="8sp" />
        </LinearLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text=":"
            android:textColor="#8A99AD"
            android:textSize="18sp"
            android:layout_marginLeft="4dp"
            android:layout_marginRight="4dp"
            android:layout_gravity="center_vertical" />

        <!-- Sec -->
        <LinearLayout
            android:layout_width="48dp"
            android:layout_height="54dp"
            android:orientation="vertical"
            android:background="@drawable/digit_card_background"
            android:gravity="center">
            <TextView
                android:id="@+id/txt_seconds"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="00"
                android:textColor="#FFFFFF"
                android:textSize="20sp"
                android:textStyle="bold" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="SEC"
                android:textColor="#8A99AD"
                android:textSize="8sp" />
        </LinearLayout>
    </LinearLayout>

    <!-- Clock Status Row -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:layout_marginBottom="8dp">
        <TextView
            android:id="@+id/txt_clock_status"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Time Remaining to Settle Your Bill"
            android:textColor="#FFEE4D2D"
            android:textSize="11sp"
            android:textStyle="bold" />
    </LinearLayout>

    <!-- Amortization Breakdown (3 Static Rows) -->
    <LinearLayout
        android:id="@+id/breakdown_container"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_marginBottom="8dp"
        android:padding="4dp"
        android:background="#1AFFFFFF"
        android:visibility="visible">

        <!-- Row 1 -->
        <RelativeLayout
            android:id="@+id/breakdown_row_1"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="2dp"
            android:visibility="gone">
            <TextView
                android:id="@+id/txt_row_1_desc"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Item 1"
                android:textColor="#CFD8DC"
                android:textSize="10sp"
                android:layout_alignParentStart="true" />
            <TextView
                android:id="@+id/txt_row_1_val"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="₱0.00"
                android:textColor="#FFFFFF"
                android:textSize="10sp"
                android:layout_alignParentEnd="true" />
        </RelativeLayout>

        <!-- Row 2 -->
        <RelativeLayout
            android:id="@+id/breakdown_row_2"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="2dp"
            android:visibility="gone">
            <TextView
                android:id="@+id/txt_row_2_desc"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Item 2"
                android:textColor="#CFD8DC"
                android:textSize="10sp"
                android:layout_alignParentStart="true" />
            <TextView
                android:id="@+id/txt_row_2_val"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="₱0.00"
                android:textColor="#FFFFFF"
                android:textSize="10sp"
                android:layout_alignParentEnd="true" />
        </RelativeLayout>

        <!-- Row 3 -->
        <RelativeLayout
            android:id="@+id/breakdown_row_3"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:visibility="gone">
            <TextView
                android:id="@+id/txt_row_3_desc"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Item 3"
                android:textColor="#CFD8DC"
                android:textSize="10sp"
                android:layout_alignParentStart="true" />
            <TextView
                android:id="@+id/txt_row_3_val"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="₱0.00"
                android:textColor="#FFFFFF"
                android:textSize="10sp"
                android:layout_alignParentEnd="true" />
        </RelativeLayout>
    </LinearLayout>

    <!-- Vertical Spacer to push footer to the bottom -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1" />

    <!-- Amount Due & Pay Button Footer -->
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_alignParentStart="true"
            android:layout_centerVertical="true">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="YOUR AMOUNT DUE"
                android:textColor="#8A99AD"
                android:textSize="8sp" />
            <TextView
                android:id="@+id/txt_amount_due"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="₱0.00"
                android:textColor="#FFFFFF"
                android:textSize="16sp"
                android:textStyle="bold" />
        </LinearLayout>

        <Button
            android:id="@+id/btn_pay_now"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:background="@drawable/pay_now_button_background"
            android:text="Pay Now"
            android:textColor="#FFFFFF"
            android:textSize="12sp"
            android:textStyle="bold"
            android:paddingLeft="12dp"
            android:paddingRight="12dp"
            android:layout_alignParentEnd="true"
            android:layout_centerVertical="true" />
    </RelativeLayout>
</LinearLayout>
